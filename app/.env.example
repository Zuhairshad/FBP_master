# Supabase project (Settings -> API in the Supabase dashboard, or `supabase status` locally)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# The Cloudflare Worker (worker/) — privileged calls (Shopify OAuth/sync, and
# every future marketplace integration) go through it via fetch, never
# directly from the browser. `pnpm dev:worker` runs it locally on this port.
VITE_WORKER_URL=http://localhost:8787
